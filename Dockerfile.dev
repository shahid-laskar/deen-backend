# Lightweight dev image — installs deps on startup via uv
# Optimised for fast iteration: no multi-stage, full source mounted as volume

FROM python:3.12-slim

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python deps via uv into the system Python (simpler for dev)
COPY pyproject.toml uv.lock* ./
RUN uv pip install --system -e ".[dev]"

# App code will be mounted as a volume at runtime
COPY . .

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app

EXPOSE 8000

CMD ["sh", "-c", "alembic upgrade head && uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload"]
