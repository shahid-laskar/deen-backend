# ─── Application ───────────────────────────────────────────────────────────────
APP_NAME="Deen"
APP_VERSION="1.0.0"
ENVIRONMENT="development"            # development | staging | production
DEBUG=true
FRONTEND_URL="http://localhost:5173"

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://deen_user:yourpassword@localhost:5432/deen_db"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY="CHANGE_ME_generate_with_openssl_rand_hex_64"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Encryption (female health data) ───────────────────────────────────────────
ENCRYPTION_MASTER_KEY="CHANGE_ME_generate_with_openssl_rand_hex_64"

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ─── AI Providers ──────────────────────────────────────────────────────────────
GEMINI_API_KEY="your_gemini_api_key"
GROQ_API_KEY="your_groq_api_key"
AI_DAILY_LIMIT_PER_USER=20          # free tier sustainability
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7

# ─── External APIs ─────────────────────────────────────────────────────────────
ALADHAN_API_URL="https://api.aladhan.com/v1"
QURAN_API_URL="https://api.quran.com/api/v4"
QURAN_AUDIO_URL="https://cdn.islamhouse.com"

# ─── OAuth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS='["http://localhost:5173","http://localhost:3000"]'
